{
  "name": "@registry/desktopapp",
  "private": true,
  "version": "0.1.0",
  "description": "Desktop launcher for Registry by Tenra.",
  "author": "tenra",
  "type": "module",
  "main": "./dist/main.cjs",
  "scripts": {
    "build": "node ./scripts/build.mjs",
    "package:mac": "electron-builder --mac dir --publish never",
    "install:mac": "node ./scripts/install-macos.mjs",
    "lint": "eslint . --ext .mjs,.ts",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "verify": "pnpm lint && pnpm typecheck && pnpm build"
  },
  "devDependencies": {
    "electron": "^41.3.0",
    "electron-builder": "^26.8.1",
    "esbuild": "^0.27.2"
  },
  "build": {
    "appId": "co.tenra.registry.desktop",
    "productName": "Registry by Tenra",
    "directories": {
      "buildResources": "assets",
      "output": "../../dist/desktop"
    },
    "files": [
      "package.json",
      "dist/**/*"
    ],
    "asar": false,
    "mac": {
      "icon": "icon.icns",
      "category": "public.app-category.business",
      "target": [
        "dir"
      ]
    }
  }
}
