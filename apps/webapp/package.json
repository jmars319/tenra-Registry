{
  "name": "@registry/webapp",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "db:generate": "node ./scripts/run-prisma.mjs generate",
    "db:migrate": "node ./scripts/run-prisma.mjs migrate dev --name registry_update",
    "db:seed": "node ./scripts/run-prisma.mjs db seed",
    "db:check": "node ./scripts/db-check.mjs",
    "db:smoke": "pnpm exec tsx ./scripts/verify-db-flow.ts",
    "lint": "eslint . --ext .ts,.tsx",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "verify": "pnpm lint && pnpm typecheck && pnpm db:check && pnpm db:smoke && pnpm build"
  },
  "dependencies": {
    "@prisma/adapter-pg": "latest",
    "@prisma/client": "latest",
    "@registry/api-contracts": "workspace:*",
    "@registry/auth": "workspace:*",
    "@registry/config": "workspace:*",
    "@registry/domain": "workspace:*",
    "@registry/ui": "workspace:*",
    "@registry/validation": "workspace:*",
    "next": "latest",
    "pg": "latest",
    "react": "latest",
    "react-dom": "latest",
    "server-only": "latest"
  },
  "devDependencies": {
    "@types/react": "latest",
    "@types/react-dom": "latest",
    "prisma": "latest",
    "tsx": "latest"
  }
}
